      ]
    },
    "srs_airbag_light": {
      "symptom": "Testigo airbag enciende permanente",
      "steps": [
        {"step": 1, "check": "leer DTCs SRS con scanner capaz (no OBD-II basico)"},
        {"step": 2, "if_B0001_2": "revisar conector reloj espiral volante"},
        {"step": 3, "if_B0022_23": "resistencia airbag conductor 2-5 ohm"},
        {"step": 4, "if_short_circuit": "reemplazar cable/modulo afectado"},
        {"step": 5, "warning": "SIEMPRE desconectar bateria 10+ min antes de tocar airbag"},
        {"step": 6, "clear_codes": "con scanner SRS (no OBD-II)"}
      ]
    },
    "evap_leak_p0456": {
      "symptom": "P0456 (fuga EVAP muy pequeña)",
      "steps": [
        {"step": 1, "check": "tapa combustible bien cerrada (click audible)"},
        {"step": 2, "if_tapa_vieja": "reemplazar tapa ($10-30) y borrar codigo"},
        {"step": 3, "if_vuelve": "smoke test al sistema EVAP"},
        {"step": 4, "if_fuga_canister": "reemplazar canister o orings"},
        {"step": 5, "if_fuga_purge_valve": "reemplazar valvula purga"}
      ]
    },
    "transmision_deslizando": {
      "symptom": "Transmision se resbala (no engancha marcha)",
      "steps": [
        {"step": 1, "check": "nivel y color ATF (debe ser rojo traslucido)"},
        {"step": 2, "if_bajo": "verificar fugas bomba/sellos/enfriador"},
        {"step": 3, "if_quemado": "requiere overhaul o reemplazo"},
        {"step": 4, "if_ok": "scanner - leer DTCs TCM + datos solenoides"},
        {"step": 5, "if_codigo_solenoide": "reemplazar solenoide ($150-500)"},
        {"step": 6, "if_sin_codigos": "test dinamico presion hidraulica"}
      ]
    },
    "glow_plug_diesel": {
      "symptom": "Diesel arranca mal en frio, humo blanco al arranque",
      "steps": [
        {"step": 1, "check": "tension bujias precalentamiento con llave ON (11-12V durante ~5-10s)"},
        {"step": 2, "check": "resistencia bujias (<1 ohm OK, >3 ohm o abierto = falla)"},
        {"step": 3, "if_abierto": "reemplazar bujia (todas mismo juego, $15-40 c/u)"},
        {"step": 4, "if_bujias_ok": "verificar rele calentamiento"},
        {"step": 5, "if_rele_ok": "ECU control y sensor temperatura motor"}
      ]
    },
    "dpf_regen_problem": {
      "symptom": "DPF no regenera, testigo encendido, consumo aumenta",
      "steps": [
        {"step": 1, "check": "leer datos live: % hollin DPF, temperatura pre/post DPF, contador regens"},
        {"step": 2, "if_hollin_>90": "regen forzada estatica con scanner (requiere tool profesional)"},
        {"step": 3, "if_regen_falla": "verificar sensor presion diferencial DPF"},
        {"step": 4, "check": "ensayo ruta 30 min 3000+ rpm para regen pasiva"},
        {"step": 5, "if_saturado": "limpieza quimica o reemplazo DPF"},
        {"step": 6, "warning": "delete DPF es ILEGAL en casi todos los paises"}
      ]
    },
    "battery_drain_parasitic": {
      "symptom": "Bateria descargada despues 1-3 dias",
      "steps": [
        {"step": 1, "check": "estado bateria con carga de prueba (load test)"},
        {"step": 2, "if_bateria_mala": "reemplazar bateria ($80-250)"},
        {"step": 3, "if_bateria_ok": "amperaje parasito: amperimetro en serie despues sleep 30 min"},
        {"step": 4, "expected": "<50 mA con todo apagado y alarma armada"},
        {"step": 5, "if_mayor": "pulling fusibles 1 por 1 para aislar circuito culpable"},
        {"step": 6, "common": "luz maletero/guantera stuck on, modulo no duerme, radio aftermarket"}
      ]
    },
    "abs_warning_constante": {
      "symptom": "Testigo ABS permanente, frenos basicos OK",
      "steps": [
        {"step": 1, "scan": "leer DTCs C-codes con scanner ABS"},
        {"step": 2, "if_C0035_40_45_50": "sensor rueda especifico - reemplazar"},
        {"step": 3, "check_sensor": "resistencia tipica 1000-1500 ohm, voltaje en movimiento 0.5-2V AC"},
        {"step": 4, "if_anillo_dañado": "reemplazar rodamiento con tono (incluye anillo)"},
        {"step": 5, "if_modulo_ABS_falla": "reemplazo o reparacion modulo (ej Bosch 8.0/8.1)"}
      ]
    },
    "cat_efficiency_p0420": {
      "symptom": "P0420 (eficiencia cat banco 1)",
      "steps": [
        {"step": 1, "check_O2": "senales O2 upstream vs downstream - upstream oscila 0.1-0.9V, downstream debe estar ~casi plano ~0.5-0.7V"},
        {"step": 2, "if_downstream_oscila_igual": "catalizador gastado (eficiencia <95%)"},
        {"step": 3, "but_first": "descartar fuga escape pre-cat con humo o estetoscopio"},
        {"step": 4, "if_fuga": "sellar antes reemplazar cat (fuga contamina lectura)"},
        {"step": 5, "cost": "cat OEM $300-1500, aftermarket $100-400"},
        {"step": 6, "fraud_warning": "straight pipe / delete es ilegal emisiones"}
      ]
    },
    "power_steering_electric_fail": {
      "symptom": "Direccion electrica se pone pesada, testigo EPS",
