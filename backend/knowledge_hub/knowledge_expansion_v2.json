      "symptom": "Aceite tipo cafe/mayonesa, o coolant con aceite",
      "steps": [
        {"step": 1, "if_mayonesa_solo_tapa": "condensacion normal en viajes cortos frio"},
        {"step": 2, "if_mayonesa_bayoneta": "junta cabeza rota o grieta"},
        {"step": 3, "test_compresion": "cilindro afectado baja presion, burbujas en radiador"},
        {"step": 4, "test_gases_coolant": "block tester con liquido reactivo"},
        {"step": 5, "if_positivo": "junta cabeza + verificar maquinado cabeza + torque TTY"},
        {"step": 6, "worst_case": "cilindros rayados - rectificacion/overhaul"}
      ]
    },
    "humo_azul_persistente": {
      "symptom": "Humo azul persistente por escape",
      "steps": [
        {"step": 1, "consumo_aceite": "registrar millas por litro consumido"},
        {"step": 2, "if_aceleracion": "sellos de valvulas (pasan aceite al ralenti-aceleracion)"},
        {"step": 3, "if_continuo": "anillos gastados (pistones/cilindros)"},
        {"step": 4, "test_compresion_humedo_seco": "si seco bajo pero humedo mejora = anillos"},
        {"step": 5, "if_turbo_car": "turbo leak por sellos - inspeccionar intercooler por aceite"},
        {"step": 6, "cost": "sellos valvula $300-800, anillos $1500-3500"}
      ]
    },
    "vibracion_ralenti": {
      "symptom": "Vibracion fuerte ralenti, desaparece aceleracion",
      "steps": [
        {"step": 1, "scan_misfire": "verificar misfire counter por cilindro"},
        {"step": 2, "if_clean": "soportes motor rotos/colapsados - inspeccion visual"},
        {"step": 3, "if_misfire": "bujia/bobina/inyector cilindro afectado"},
        {"step": 4, "check_vacuum_leak": "humo o propano en carburador/TB"},
        {"step": 5, "balancin_turbo": "en motores con balance shaft - chain stretch"},
        {"step": 6, "idle_relearn": "tras reparacion, reset adaptaciones ECU"}
      ]
    },
    "fan_noise_sobrecarga": {
      "symptom": "Ventilador radiador full speed siempre, motor temp normal",
      "steps": [
        {"step": 1, "scan": "codigo P0480 (circuito rele ventilador)"},
        {"step": 2, "if_fan_stuck_on_KOEO": "rele ventilador pegado ON"},
        {"step": 3, "check_AC_pressure": "alta presion AC dispara ventilador"},
        {"step": 4, "check_ECT_signal": "sensor ECT dando lectura alta falsa"},
        {"step": 5, "check_PCM_control": "si PCM mantiene comando = modulo fan o PCM"}
      ]
    }
