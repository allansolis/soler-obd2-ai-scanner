  "decision_trees_extended": {
    "tpms_warning": {
      "symptom": "Testigo TPMS enciende",
      "steps": [
        {"step": 1, "check": "presion fisica 4 llantas con manometro"},
        {"step": 2, "if_low": "inflar a especificacion puerta (tipicamente 30-35 PSI)"},
        {"step": 3, "if_ok": "escaner - leer presiones reportadas por cada sensor"},
        {"step": 4, "if_missing": "sensor fallado - reemplazar (~$30-100 c/u)"},
