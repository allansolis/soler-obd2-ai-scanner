      "symptom": "Check engine parpadeando (misfire critico)",
      "steps": [
        {"step": 1, "CRITICO": "misfire activo puede dañar catalizador en minutos - reducir carga"},
        {"step": 2, "scan": "P0300 + P030X identifica cilindro(s)"},
        {"step": 3, "swap_test": "swap bobina/bujia a cilindro vecino - si el codigo sigue = inyector"},
        {"step": 4, "if_sigue_tras_swap": "inyector fugando o compresion baja"},
        {"step": 5, "check_compression": "test compresion - diferencia >15% entre cilindros = problema mecanico"}
      ]
    },
    "intermitent_no_start": {
      "symptom": "A veces arranca, a veces no, sin patron obvio",
      "steps": [
        {"step": 1, "cuando_no_arranca": "escuchar arranque - ¿gira motor?"},
        {"step": 2, "no_gira": "bateria/arrancador/rele - test voltaje al solenoide arrancador"},
        {"step": 3, "gira_pero_no_prende": "no hay chispa o no hay combustible"},
        {"step": 4, "check_spark": "remover bobina y ver chispa contra masa"},
        {"step": 5, "check_fuel_pressure": "al momento de giro"},
        {"step": 6, "common_intermittent": "crank sensor se expande con calor, falla aleatoria"}
      ]
    },
